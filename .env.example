# ATS  Screener — copy this to .env and fill in your values

# Required: your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional overrides (all have sensible defaults)
# ATS_GEMINI_MODEL=gemini-2.5-flash
# ATS_MIN_SCORE=5.0
# ATS_TOP_K=10
# ATS_MAX_WORKERS=4
# ATS_CACHE_TTL_HOURS=24
